#!/bin/bash
set -euo pipefail

source ./assert.sh
source ./start-fresh.sh >/dev/null

echo
echo ==========================================================
echo

#
# Compare the grants between two schemas in the same database
#

./populate-db.sh db1 "
    CREATE SCHEMA s1;
    CREATE TABLE s1.table1 (id integer);
    GRANT INSERT, UPDATE ON s1.table1 TO u2;
    CREATE TABLE s1.table2 (id integer);
    GRANT SELECT ON s1.table2 TO u2;
    CREATE TABLE s1.table3 (id integer);
    GRANT SELECT ON s1.table3 TO u2;
    CREATE TABLE s1.table4 (id integer);
    GRANT SELECT ON s1.table4 TO u2 WITH GRANT OPTION;
    CREATE TABLE s1.table5 (id integer);
    GRANT SELECT ON s1.table5 TO u2;

    CREATE SCHEMA s2;
    CREATE TABLE s2.table1 (id integer);
    GRANT SELECT ON s2.table1 TO u2;
    CREATE TABLE s2.table2 (id integer);
    GRANT SELECT ON s2.table2 TO u2;
    CREATE TABLE s2.table3 (id integer);
    GRANT SELECT ON s2.table3 TO u1;
    CREATE TABLE s2.table4 (id integer);
    GRANT SELECT ON s2.table4 TO u2;
    CREATE TABLE s2.table5 (id integer);
    GRANT SELECT ON s2.table5 TO u2 WITH GRANT OPTION;
"

echo
echo "# Compare the grants between two schemas in the same database"
echo "# Expect normal grant diffs plus grant-option upgrade/downgrade"
echo

output=$(../pgdiff -U "u1" -W "asdf" -H "localhost" -D "db1" -S "s1" -O "sslmode=disable" \
                  -u "u1" -w "asdf" -h "localhost" -d "db1" -s "s2" -o "sslmode=disable" \
                  GRANT_RELATIONSHIP | clean_pgdiff_output)
assert_contains "$output" "REVOKE SELECT ON s2.table1 FROM u2; -- Change"
assert_contains "$output" "GRANT INSERT, UPDATE ON s2.table1 TO u2; -- Change"
assert_contains "$output" "GRANT SELECT ON s2.table3 TO u2; -- Add"
assert_contains "$output" "GRANT SELECT ON s2.table4 TO u2 WITH GRANT OPTION; -- Change"
assert_contains "$output" "REVOKE GRANT OPTION FOR SELECT ON s2.table5 FROM u2; -- Change"
printf '%s\n' "$output"

echo
echo ==========================================================
echo

#
# Compare the grants in all schemas between two databases
#
./populate-db.sh db2 "
    CREATE SCHEMA s1;
    CREATE TABLE s1.table1 (id integer);
    GRANT SELECT ON s1.table1 TO u2;
    CREATE TABLE s1.table2 (id integer);
    GRANT SELECT ON s1.table2 TO u2;
    CREATE TABLE s1.table3 (id integer);
    GRANT SELECT ON s1.table3 TO u2;

    CREATE SCHEMA s2;
    CREATE TABLE s2.table1 (id integer);
    GRANT SELECT ON s2.table1 TO u2;
    CREATE TABLE s2.table2 (id integer);
    GRANT SELECT ON s2.table2 TO u2;
    CREATE TABLE s2.table3 (id integer);
    GRANT UPDATE ON s2.table3 TO u2;
"

echo
echo "# Compare the grants in all schemas between two databases"
echo "# Expect SQL (pseudocode):"
echo "#   Revoke UPDATE        on s2.table3 for u2"
echo "#   Grant  INSERT,UPDATE on s1.table1 for u2"
echo "#   Revoke SELECT        on s1.table1 for u2"
echo

output=$(../pgdiff -U "u1" -W "asdf" -H "localhost" -D "db1" -S "*" -O "sslmode=disable" \
                  -u "u1" -w "asdf" -h "localhost" -d "db2" -s "*" -o "sslmode=disable" \
                  GRANT_RELATIONSHIP | clean_pgdiff_output)
assert_contains "$output" "REVOKE UPDATE ON s2.table3 FROM u2; -- Drop"
assert_contains "$output" "GRANT INSERT, UPDATE ON s1.table1 TO u2; -- Change"
assert_contains "$output" "REVOKE SELECT ON s1.table1 FROM u2; -- Change"
printf '%s\n' "$output"
echo
echo
